# ===== GROT — переменные окружения =====
# Скопируйте в backend/.env (локально) или задайте в дашборде хостинга.
# Без этих ключей приложение работает в демо-режиме и НЕ ломается.

# Порт и режим
PORT=4000
NODE_ENV=development

# --- Безопасность ---
# Секрет для подписи токенов. Если не задать — сгенерируется и сохранится в data/.secret.
# В проде ЛУЧШЕ задать явно (длинная случайная строка), чтобы токены были стабильны.
AUTH_SECRET=
# Разрешённые источники для CORS в проде (через запятую). Для single-origin можно не задавать.
ALLOWED_ORIGINS=

# Путь к файлу состояния (в облаке указывайте путь на volume)
DATA_FILE=./data/store.json

# --- Web Push (бесплатно). Сгенерировать пару ключей:
#     npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:admin@grot.app

# --- SMS / OTP (Twilio). Без них код приходит в ответе (demo).
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# --- Карты / доставка (Google Maps). Без ключа — фиксированная зона Pattaya.
GOOGLE_MAPS_KEY=
GOOGLE_MAPS_BROWSER_KEY=
RESTAURANT_LAT=12.9236
RESTAURANT_LNG=100.8825
DELIVERY_RADIUS_KM=8
